digraph solar_os_architecture {
    graph [
        rankdir=TB,
        bgcolor="#ffffff",
        pad="0.35",
        nodesep="0.78",
        ranksep="1.00",
        compound=true,
        splines=ortho,
        outputorder=edgesfirst,
        fontname="DejaVu Sans",
        labelloc=t,
        label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                <TR><TD><FONT POINT-SIZE="24"><B>SolarOS Architecture</B></FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="11">Waveshare ESP32-S3-RLCD-4.2 firmware</FONT></TD></TR>
            </TABLE>
        >
    ];

    node [
        shape=box,
        style="rounded,filled",
        fontname="DejaVu Sans",
        fontsize=12,
        color="#475569",
        penwidth=1.4,
        margin="0.14,0.10",
        fillcolor="#f8fafc"
    ];

    edge [
        color="#64748b",
        penwidth=1.8,
        arrowsize=0.8
    ];

    subgraph cluster_top {
        label="Applications, Jobs, and Python";
        color="#bfdbfe";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#eff6ff";
        fontsize=15;
        fontname="DejaVu Sans";

        apps [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Foreground apps</B></TD></TR>
                    <TR><TD>shell, clock, edit, com</TD></TR>
                    <TR><TD>ssh, scp, curl</TD></TR>
                    <TR><TD>arecord, aplay, python</TD></TR>
                </TABLE>
            >,
            fillcolor="#dbeafe",
            color="#2563eb"
        ];

        jobs [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Background jobs</B></TD></TR>
                    <TR><TD>httpd static file server</TD></TR>
                    <TR><TD>ntp-sync RTC sync</TD></TR>
                    <TR><TD>start, stop, tick lifecycle</TD></TR>
                </TABLE>
            >,
            fillcolor="#dcfce7",
            color="#16a34a"
        ];

        python [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Python modules</B></TD></TR>
                    <TR><TD>MicroPython REPL + .py/.mpy</TD></TR>
                    <TR><TD>native <B>solaros</B> module via services</TD></TR>
                    <TR><TD>storage, time, wifi, i2c, uart</TD></TR>
                    <TR><TD>audio, ble, clipboard, jobs, apps</TD></TR>
                </TABLE>
            >,
            fillcolor="#fef3c7",
            color="#d97706"
        ];

        { rank=same; apps; jobs; python; }
    }

    subgraph cluster_runtime {
        label="SolarOS Runtime Core";
        color="#c4b5fd";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#f5f3ff";
        fontsize=15;
        fontname="DejaVu Sans";

        runtime [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>app_main loop</B></TD></TR>
                    <TR><TD>boot init, keyboard dispatch</TD></TR>
                    <TR><TD>25 ms app ticks and job ticks</TD></TR>
                    <TR><TD>status bar and display draw</TD></TR>
                </TABLE>
            >,
            fillcolor="#ede9fe",
            color="#7c3aed"
        ];

        context [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>solar_os_context_t</B></TD></TR>
                    <TR><TD>terminal and graphics handles</TD></TR>
                    <TR><TD>launch, exit, argc, argv</TD></TR>
                </TABLE>
            >,
            fillcolor="#ede9fe",
            color="#7c3aed"
        ];

        registry [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Registries and scheduler</B></TD></TR>
                    <TR><TD>app registry</TD></TR>
                    <TR><TD>job registry and runtime state</TD></TR>
                </TABLE>
            >,
            fillcolor="#ede9fe",
            color="#7c3aed"
        ];

        { rank=same; runtime; context; registry; }
    }

    subgraph cluster_services {
        label="Services: shared OS capabilities";
        color="#99f6e4";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#f0fdfa";
        fontsize=15;
        fontname="DejaVu Sans";

        ui_services [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>UI and input</B></TD></TR>
                    <TR><TD>terminal, graphics</TD></TR>
                    <TR><TD>BLE keyboard, clipboard, identity</TD></TR>
                </TABLE>
            >,
            fillcolor="#ccfbf1",
            color="#0f766e"
        ];

        storage_services [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Storage</B></TD></TR>
                    <TR><TD>SD mount and volumes</TD></TR>
                    <TR><TD>paths, files, shell history</TD></TR>
                </TABLE>
            >,
            fillcolor="#ccfbf1",
            color="#0f766e"
        ];

        net_services [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Network</B></TD></TR>
                    <TR><TD>Wi-Fi STA/AP/NAT, ping</TD></TR>
                    <TR><TD>SSH, SCP, SSH keys, HTTP users</TD></TR>
                </TABLE>
            >,
            fillcolor="#ccfbf1",
            color="#0f766e"
        ];

        hw_services [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Hardware policy</B></TD></TR>
                    <TR><TD>battery, sensors, time</TD></TR>
                    <TR><TD>I2C, UART, audio, RTC/NTP</TD></TR>
                </TABLE>
            >,
            fillcolor="#ccfbf1",
            color="#0f766e"
        ];

        { rank=same; ui_services; storage_services; net_services; hw_services; }
    }

    subgraph cluster_drivers {
        label="Board Drivers";
        color="#fed7aa";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#fff7ed";
        fontsize=15;
        fontname="DejaVu Sans";

        display_driver [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Display</B></TD></TR>
                    <TR><TD>rlcd_st7305</TD></TR>
                    <TR><TD>U8g2 bridge and framebuffer</TD></TR>
                </TABLE>
            >,
            fillcolor="#ffedd5",
            color="#ea580c"
        ];

        bus_drivers [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Bus and storage</B></TD></TR>
                    <TR><TD>I2C bus, SD card</TD></TR>
                    <TR><TD>UART port</TD></TR>
                </TABLE>
            >,
            fillcolor="#ffedd5",
            color="#ea580c"
        ];

        peripheral_drivers [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Peripherals</B></TD></TR>
                    <TR><TD>PCF85063 RTC, SHTC3</TD></TR>
                    <TR><TD>battery ADC, audio codec board</TD></TR>
                </TABLE>
            >,
            fillcolor="#ffedd5",
            color="#ea580c"
        ];

        { rank=same; display_driver; bus_drivers; peripheral_drivers; }
    }

    subgraph cluster_foundation {
        label="ESP-IDF, FreeRTOS, and Components";
        color="#cbd5e1";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#f8fafc";
        fontsize=15;
        fontname="DejaVu Sans";

        rtos [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>FreeRTOS</B></TD></TR>
                    <TR><TD>tasks, queues, delays</TD></TR>
                    <TR><TD>foreground loop and worker tasks</TD></TR>
                </TABLE>
            >,
            fillcolor="#e2e8f0",
            color="#475569"
        ];

        idf [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>ESP-IDF core</B></TD></TR>
                    <TR><TD>esp_event, esp_timer, heap</TD></TR>
                    <TR><TD>NVS, VFS, logging</TD></TR>
                </TABLE>
            >,
            fillcolor="#e2e8f0",
            color="#475569"
        ];

        esp_drivers [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>IDF drivers</B></TD></TR>
                    <TR><TD>GPIO, SPI, I2C, I2S</TD></TR>
                    <TR><TD>SDMMC, UART, ADC</TD></TR>
                </TABLE>
            >,
            fillcolor="#e2e8f0",
            color="#475569"
        ];

        stacks_components [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Stacks and components</B></TD></TR>
                    <TR><TD>Wi-Fi, esp_netif, LwIP, BLE HID</TD></TR>
                    <TR><TD>u8g2, MicroPython embed</TD></TR>
                    <TR><TD>libssh2_esp, esp_codec_dev, fatfs, HTTP</TD></TR>
                </TABLE>
            >,
            fillcolor="#e2e8f0",
            color="#475569"
        ];

        { rank=same; rtos; idf; esp_drivers; stacks_components; }
    }

    subgraph cluster_hardware {
        label="Board Hardware";
        color="#fecdd3";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#fff1f2";
        fontsize=15;
        fontname="DejaVu Sans";

        board [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Waveshare ESP32-S3-RLCD-4.2</B></TD></TR>
                    <TR><TD>ESP32-S3-WROOM-1-N16R8</TD></TR>
                    <TR><TD>240 MHz dual core, 16 MB flash, 8 MB PSRAM</TD></TR>
                </TABLE>
            >,
            fillcolor="#ffe4e6",
            color="#e11d48"
        ];

        peripherals [
            label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><B>Attached peripherals</B></TD></TR>
                    <TR><TD>400 x 300 ST7305 LCD, SD slot</TD></TR>
                    <TR><TD>BLE keyboard, Wi-Fi, RTC, SHTC3</TD></TR>
                    <TR><TD>UART pins, battery monitor, audio codec</TD></TR>
                </TABLE>
            >,
            fillcolor="#ffe4e6",
            color="#e11d48"
        ];

        { rank=same; board; peripherals; }
    }

    apps -> runtime;
    jobs -> registry;
    python -> apps [style=dashed];

    runtime -> context;
    runtime -> registry;

    context -> ui_services [lhead=cluster_services];

    ui_services -> display_driver;
    storage_services -> bus_drivers;
    net_services -> stacks_components;
    hw_services -> bus_drivers;
    hw_services -> peripheral_drivers;

    display_driver -> esp_drivers;
    display_driver -> stacks_components;
    bus_drivers -> esp_drivers;
    peripheral_drivers -> esp_drivers;
    peripheral_drivers -> stacks_components;

    idf -> rtos [dir=both];
    esp_drivers -> idf;
    stacks_components -> idf;

    rtos -> board;
    idf -> board;
    esp_drivers -> peripherals;
    stacks_components -> peripherals;
}
